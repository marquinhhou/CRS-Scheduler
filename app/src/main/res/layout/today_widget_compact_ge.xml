<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_ge"
    android:clipToOutline="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="3dp">

                <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:src="@drawable/dot_accent_ge" />

            <TextView
                android:id="@+id/header_brand_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="TODAY"
                android:textColor="@color/ge_ink_dim"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_settings_ge" />

            <ImageView
                android:id="@+id/btn_view_full_schedule"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_calendar_ge" />

            <ImageView
                android:id="@+id/btn_save"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_save_ge" />

            <TextView
                android:id="@+id/btn_form5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="F5"
                android:textColor="@color/ge_ink_dim"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextClock
                    android:id="@+id/clock_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="h:mm"
                    android:format24Hour="HH:mm"
                    android:textColor="@color/ge_ink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextClock
                    android:id="@+id/clock_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="EEE, MMM d"
                    android:format24Hour="EEE, MMM d"
                    android:textAllCaps="true"
                    android:textColor="@color/ge_ink_dim"
                    android:textSize="9.5sp"
                    android:letterSpacing="0.12" />
            </LinearLayout>
        </LinearLayout>

                <FrameLayout
            android:id="@+id/hero_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_ge"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/hero_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/hero_ring"
                    android:layout_width="52dp"
                    android:layout_height="52dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/hero_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ge_accent"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/hero_class"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ge_ink"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/hero_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ge_ink_dim"
                        android:textSize="10sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="3dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/hero_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/hero_empty_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/ge_ink"
                    android:textStyle="bold"
                    android:textSize="12.5sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:scaleType="fitXY"
        android:src="@drawable/fade_bottom_ge" />

</FrameLayout>
