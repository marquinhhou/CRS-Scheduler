<?xml version="1.0" encoding="utf-8"?>
<!--
  Root here is a plain, backgroundless slot. This item is hosted inside a
  ListView via TodayClassesRemoteViewsService's RemoteViewsFactory, and
  margins on the root view of an AdapterView-backed RemoteViews row are not
  reliably honored by the platform/launcher host, unlike padding, which
  is. Reserving the inter-row gap as real paddingBottom here (instead of a
  layout_marginBottom on the card itself, and instead of the ListView's own
  dividerHeight, which is equally inconsistent once android:divider is
  null) keeps row_root's rounded card fully inset from this slot's true
  edges. That way nothing the host does at a row's boundary, recycling,
  divider math, whatever, can ever bite into the visible rounded corners,
  which is what was happening before: the top of every row's card was
  getting hard-clipped, flattening its top corners while the bottom stayed
  fully rounded.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_class_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/row_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/row_bg"
        android:padding="8dp">

        <TextView
            android:id="@+id/row_time"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_dim"
            android:textSize="10.5sp"
            android:fontFamily="@font/jetbrains_mono"
            android:lineSpacingMultiplier="1.3" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/row_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textStyle="bold"
                android:textSize="13.5sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/jetbrains_mono_bold" />

            <TextView
                android:id="@+id/row_room"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_dim"
                android:textSize="10.5sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/jetbrains_mono" />
        </LinearLayout>

        <ImageView
            android:id="@+id/row_badge"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:src="@drawable/dot_dim" />

    </LinearLayout>

</FrameLayout>
