<?xml version="1.0" encoding="utf-8"?>
<!--
     Shown instead of week_widget.xml when the widget is resized tall enough to
     fit a CRS-style time/day grid (see WidgetRenderer.buildWeekSummary()). The
     grid rows themselves are built at runtime and added into week_table_container
     (one row per distinct time breakpoint across the week's classes), the same
     addView() pattern already used for week_dots_row.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- header: brand + gear + clock (matches the Today card for a consistent stack) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:src="@drawable/dot_red" />

            <TextView
                android:id="@+id/header_brand_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="WEEKLY"
                android:textColor="@color/ink_dim"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:fontFamily="@font/jetbrains_mono" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_settings" />

            <LinearLayout
                android:id="@+id/btn_view_full_schedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/chip_outline_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIEW FULL"
                    android:textColor="@color/red"
                    android:textStyle="bold"
                    android:textSize="8.5sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/jetbrains_mono_bold" />
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextClock
                    android:id="@+id/clock_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="h:mm"
                    android:format24Hour="HH:mm"
                    android:textColor="@color/ink"
                    android:textSize="20sp"
                    android:fontFamily="@font/dotgothic16" />

                <TextClock
                    android:id="@+id/clock_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="EEE, MMM d"
                    android:format24Hour="EEE, MMM d"
                    android:textAllCaps="true"
                    android:textColor="@color/ink_dim"
                    android:textSize="9.5sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/jetbrains_mono" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/table_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textStyle="bold"
            android:textSize="12.5sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/jetbrains_mono_bold" />

        <!-- CRS-style grid: a header row (day letters) followed by one row per
             distinct time breakpoint, built in WidgetRenderer.buildWeekTable(). -->
        <LinearLayout
            android:id="@+id/week_table_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/row_bg"
            android:padding="6dp" />

        <!-- "No classes on: Sat, Sun", explains why those day columns
             aren't in the grid above, rather than the grid just silently
             not accounting for all 7 days. GONE when every day has a class
             (see WidgetRenderer.noClassDaysLabel()). -->
        <TextView
            android:id="@+id/no_class_days_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/ink_dim"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="@font/jetbrains_mono"
            android:visibility="gone" />

    </LinearLayout>
</FrameLayout>
