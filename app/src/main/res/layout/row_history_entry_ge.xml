<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/row_bg_ge"
    android:padding="12dp"
    android:layout_marginBottom="10dp">

    <TextView
        android:id="@+id/history_row_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ge_ink"
        android:textSize="11sp"
        android:lineSpacingMultiplier="1.2"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/history_row_reactivate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="REACTIVATE"
            android:textColor="@color/ge_bg"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:background="@drawable/btn_bg_ge"
            android:backgroundTint="@color/ge_accent"
            android:foreground="@drawable/ripple_rounded_12dp_ge"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/history_row_rename"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:padding="11dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/row_bg_ge"
            android:foreground="@drawable/ripple_rounded_14dp_ge"
            android:contentDescription="Rename"
            android:src="@drawable/ic_edit_ge" />

        <ImageView
            android:id="@+id/history_row_delete"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:padding="11dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/row_bg_ge"
            android:foreground="@drawable/ripple_rounded_14dp_ge"
            android:contentDescription="Delete"
            android:src="@drawable/ic_delete_ge" />
    </LinearLayout>
</LinearLayout>
