<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/edit_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/row_bg"
    android:foreground="@drawable/ripple_rounded_14dp"
    android:clickable="true"
    android:focusable="true"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/edit_row_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textStyle="bold"
            android:textSize="13sp"
            android:fontFamily="@font/jetbrains_mono_bold" />

        <TextView
            android:id="@+id/edit_row_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/ink_dim"
            android:textSize="11sp"
            android:fontFamily="@font/jetbrains_mono" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EDIT"
        android:textColor="@color/red"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:fontFamily="@font/jetbrains_mono_bold" />

</LinearLayout>
