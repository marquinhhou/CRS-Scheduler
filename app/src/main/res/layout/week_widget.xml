<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- header: brand + gear + clock (matches the Today card for a consistent stack) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:src="@drawable/dot_red" />

            <TextView
                android:id="@+id/header_brand_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="WEEKLY"
                android:textColor="@color/ink_dim"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:fontFamily="@font/jetbrains_mono" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_settings" />

            <LinearLayout
                android:id="@+id/btn_view_full_schedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/chip_outline_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIEW FULL"
                    android:textColor="@color/red"
                    android:textStyle="bold"
                    android:textSize="8.5sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/jetbrains_mono_bold" />
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextClock
                    android:id="@+id/clock_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="h:mm"
                    android:format24Hour="HH:mm"
                    android:textColor="@color/ink"
                    android:textSize="20sp"
                    android:fontFamily="@font/dotgothic16" />

                <TextClock
                    android:id="@+id/clock_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="EEE, MMM d"
                    android:format24Hour="EEE, MMM d"
                    android:textAllCaps="true"
                    android:textColor="@color/ink_dim"
                    android:textSize="9.5sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/jetbrains_mono" />
            </LinearLayout>
        </LinearLayout>

        <!-- summary card -->
        <FrameLayout
            android:id="@+id/summary_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/summary_headline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink"
                    android:textStyle="bold"
                    android:textSize="15.5sp"
                    android:fontFamily="@font/jetbrains_mono_bold" />

                <TextView
                    android:id="@+id/summary_sub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink_dim"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/jetbrains_mono" />

                <TextView
                    android:id="@+id/summary_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink_dim"
                    android:textSize="10.5sp"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/jetbrains_mono" />
            </LinearLayout>
        </FrameLayout>

        <!-- week-at-a-glance dots: one per day, Mon..Sun, lit if it has classes -->
        <LinearLayout
            android:id="@+id/week_dots_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center" />

    </LinearLayout>
</FrameLayout>
