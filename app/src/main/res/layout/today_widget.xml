<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- header: brand + gear + clock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:src="@drawable/dot_red" />

            <TextView
                android:id="@+id/header_brand_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="TODAY"
                android:textColor="@color/ink_dim"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:fontFamily="@font/jetbrains_mono" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_settings" />

            <LinearLayout
                android:id="@+id/btn_view_full_schedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/chip_outline_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIEW FULL"
                    android:textColor="@color/red"
                    android:textStyle="bold"
                    android:textSize="8.5sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/jetbrains_mono_bold" />
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextClock
                    android:id="@+id/clock_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="h:mm"
                    android:format24Hour="HH:mm"
                    android:textColor="@color/ink"
                    android:textSize="20sp"
                    android:fontFamily="@font/dotgothic16" />

                <TextClock
                    android:id="@+id/clock_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="EEE, MMM d"
                    android:format24Hour="EEE, MMM d"
                    android:textAllCaps="true"
                    android:textColor="@color/ink_dim"
                    android:textSize="9.5sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/jetbrains_mono" />
            </LinearLayout>
        </LinearLayout>

        <!-- hero card: now/next class -->
        <FrameLayout
            android:id="@+id/hero_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:id="@+id/hero_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/hero_ring"
                    android:layout_width="64dp"
                    android:layout_height="64dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/hero_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/red"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="@font/jetbrains_mono_bold" />

                    <TextView
                        android:id="@+id/hero_class"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ink"
                        android:textStyle="bold"
                        android:textSize="15.5sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/jetbrains_mono_bold" />

                    <TextView
                        android:id="@+id/hero_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ink_dim"
                        android:textSize="10.5sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/jetbrains_mono" />

                    <Chronometer
                        android:id="@+id/hero_countdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ink"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/dotgothic16" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/hero_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/hero_empty_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/ink"
                    android:textStyle="bold"
                    android:textSize="13.5sp"
                    android:fontFamily="@font/jetbrains_mono_bold" />

                <TextView
                    android:id="@+id/hero_empty_sub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/ink_dim"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/jetbrains_mono" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/today_list_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TODAY'S CLASSES"
                android:textColor="@color/ink_dim"
                android:textSize="10sp"
                android:letterSpacing="0.18"
                android:fontFamily="@font/jetbrains_mono" />

            <TextView
                android:id="@+id/btn_toggle_tomorrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="TMRW"
                android:textColor="@color/ink_dim"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/chip_outline_bg"
                android:fontFamily="@font/jetbrains_mono_bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/today_list_wrapper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/today_list_listview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:scrollbars="none"
                android:listSelector="@android:color/transparent"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/today_list_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:visibility="gone"
                android:text="No classes today."
                android:textColor="@color/ink_dim"
                android:textSize="11sp"
                android:fontFamily="@font/jetbrains_mono" />
        </FrameLayout>

    </LinearLayout>
</FrameLayout>
