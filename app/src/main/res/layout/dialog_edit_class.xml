<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="480dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/dialog_edit_class_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="@font/jetbrains_mono_bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ROOM / LOCATION"
            android:textColor="@color/ink_dim"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/jetbrains_mono" />

        <EditText
            android:id="@+id/dialog_input_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/row_bg"
            android:padding="12dp"
            android:hint="e.g. SS 301"
            android:textColorHint="@color/ink_dim"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:imeOptions="actionNext"
            android:fontFamily="@font/jetbrains_mono" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="INSTRUCTOR"
            android:textColor="@color/ink_dim"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/jetbrains_mono" />

        <EditText
            android:id="@+id/dialog_input_instructor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/row_bg"
            android:padding="12dp"
            android:hint="e.g. Dela Cruz, J."
            android:textColorHint="@color/ink_dim"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:imeOptions="actionNext"
            android:fontFamily="@font/jetbrains_mono" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="UNITS"
            android:textColor="@color/ink_dim"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/jetbrains_mono" />

        <EditText
            android:id="@+id/dialog_input_units"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/row_bg"
            android:padding="12dp"
            android:hint="e.g. 3.0"
            android:textColorHint="@color/ink_dim"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:inputType="numberDecimal"
            android:imeOptions="actionDone"
            android:fontFamily="@font/jetbrains_mono" />

    </LinearLayout>
</ScrollView>
