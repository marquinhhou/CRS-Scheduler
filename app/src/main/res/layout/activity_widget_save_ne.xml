<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp"
        android:background="@drawable/card_bg_now_ne">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE SCHEDULE"
            android:textColor="@color/ne_accent"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_mono_bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Save this week's schedule as..."
            android:textColor="@color/ne_ink"
            android:textStyle="bold"
            android:textSize="16sp"
            android:fontFamily="@font/jetbrains_mono_bold" />

        <Button
            android:id="@+id/btn_save_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:minHeight="48dp"
            android:text="IMAGE"
            android:textColor="@color/ne_bg"
            android:textSize="11.5sp"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_bg_ne"
            android:backgroundTint="@color/ne_accent"
            android:foreground="@drawable/ripple_rounded_12dp_ne"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_mono_bold" />

        <Button
            android:id="@+id/btn_save_ics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="48dp"
            android:text=".ICS FILE"
            android:textColor="@color/ne_ink"
            android:textSize="11.5sp"
            android:letterSpacing="0.1"
            android:background="@drawable/row_bg_ne"
            android:foreground="@drawable/ripple_rounded_14dp_ne"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_mono_bold" />

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:minHeight="32dp"
            android:gravity="center"
            android:text="Cancel"
            android:textColor="@color/ne_ink_dim"
            android:textSize="11.5sp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_rounded_10dp_ne"
            android:fontFamily="@font/jetbrains_mono" />
    </LinearLayout>
</FrameLayout>
