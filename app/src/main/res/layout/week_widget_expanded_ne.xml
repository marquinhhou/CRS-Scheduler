<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_ne"
    android:clipToOutline="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="3dp">

                <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:src="@drawable/dot_accent_ne" />

            <TextView
                android:id="@+id/header_brand_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="WEEKLY"
                android:textColor="@color/ne_ink_dim"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/jetbrains_mono" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_settings_ne" />

            <ImageView
                android:id="@+id/btn_view_full_schedule"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_calendar_ne" />

            <ImageView
                android:id="@+id/btn_save"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_save_ne" />

            <TextView
                android:id="@+id/btn_form5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="F5"
                android:textColor="@color/ne_ink_dim"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:fontFamily="@font/jetbrains_mono_bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextClock
                    android:id="@+id/clock_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="h:mm"
                    android:format24Hour="HH:mm"
                    android:textColor="@color/ne_ink"
                    android:textSize="20sp"
                    android:fontFamily="@font/dotgothic16" />

                <TextClock
                    android:id="@+id/clock_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="EEE, MMM d"
                    android:format24Hour="EEE, MMM d"
                    android:textAllCaps="true"
                    android:textColor="@color/ne_ink_dim"
                    android:textSize="9.5sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/jetbrains_mono" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/table_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ne_ink"
            android:textStyle="bold"
            android:textSize="12.5sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/jetbrains_mono_bold" />

                <LinearLayout
            android:id="@+id/week_table_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/row_bg_ne"
            android:padding="6dp" />

                <TextView
            android:id="@+id/no_class_days_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/ne_ink_dim"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="@font/jetbrains_mono"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
